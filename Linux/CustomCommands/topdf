#!/bin/sh
""":"
if [ "$(uname)" = "Darwin" ]; then
    # Check if Homebrew exists in the standard Apple Silicon path, required for weasyprint
    if [ -d "/opt/homebrew/lib" ]; then
        export DYLD_FALLBACK_LIBRARY_PATH="/opt/homebrew/lib${DYLD_FALLBACK_LIBRARY_PATH:+:$DYLD_FALLBACK_LIBRARY_PATH}"
    fi
fi

exec python3 "$0" "$@"
"""

__doc__ = "Markdown to PDF Converter"

from typing import List

import argparse
import os
import sys

# --- MAC ARM64 FIX ---
# We inject the Homebrew path directly into the process environment 
# BEFORE importing weasyprint.
if sys.platform == "darwin":
    homebrew_lib = "/opt/homebrew/lib"
    if os.path.exists(homebrew_lib):
        # 1. Update the DLL search path for cffi
        os.environ["DYLD_LIBRARY_PATH"] = f"{homebrew_lib}:{os.environ.get('DYLD_LIBRARY_PATH', '')}"
        # 2. Add to PATH just in case
        os.environ["PATH"] = f"{homebrew_lib}:{os.environ.get('PATH', '')}"

import re
import urllib.parse
import urllib.request
import markdown
import base64
import ssl

from pygments.formatters import HtmlFormatter
from weasyprint import HTML


def _get_logo_html(logo_path):
    if not logo_path or not os.path.isfile(logo_path):
        return ""
    try:
        with open(logo_path, "rb") as img_file:
            base64_str = base64.b64encode(img_file.read()).decode('utf-8')
            return f'<img class="logo-top-right" src="data:image/png;base64,{base64_str}" alt="Logo" />'
    except Exception as e:
        print(f"Warning: Failed to load logo from '{logo_path}'. Error: {e}")
        return ""


def _ensure_exists(input_file) -> None:
    if not os.path.exists(input_file):
        print(f"Error: Input file '{input_file}' not found.")
        sys.exit(1)


def _get_md_text(input_file) -> str:
    with open(input_file, 'r', encoding='utf-8') as f:
        data = f.read()
    return data


def _apply_page_breaks(md_text: str) -> str:
    return md_text.replace(r'\newpage', '<div style="page-break-before: always;"></div>')


def _fetch_math_base64(math_str: str) -> str:
    query = r'\dpi{300} \bg_white ' + math_str.strip()
    url = "https://latex.codecogs.com/png.latex?" + urllib.parse.quote(query)
    ctx = ssl.create_default_context()
    ctx.check_hostname = False
    ctx.verify_mode = ssl.CERT_NONE
    
    try:
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        with urllib.request.urlopen(req, context=ctx) as response:
            img_data = response.read()
            b64_str = base64.b64encode(img_data).decode('utf-8')
            return f"data:image/png;base64,{b64_str}"
    except Exception as e:
        print(f"Warning: Failed to fetch math from CodeCogs: {math_str} | Error: {e}")
        return ""


def _apply_mathjax(md_text: str) -> str:
    def _repl_block(m):
        b64_img = _fetch_math_base64(m.group(1))
        return f'<span style="display:block; text-align:center; margin: 15px 0;"><img src="{b64_img}" style="height: 1em; max-width: 100%;" alt="Block Math" /></span>'
    md_text = re.sub(r'(?<!\\)\$\$(.*?)(?<!\\)\$\$', _repl_block, md_text, flags=re.DOTALL)
    def _repl_inline(m):
        b64_img = _fetch_math_base64(m.group(1))
        return f'<img style="vertical-align: text-bottom; height: 1em; margin: 0 2px;" src="{b64_img}" alt="Inline Math" />'
    return re.sub(r'(?<!\\)\$(?!\s)([^$\n]+?)(?<!\s)(?<!\\)\$', _repl_inline, md_text)


def _to_html(md_text: str, extensions: List[str]) -> str:
    return markdown.markdown(md_text, extensions=extensions)


