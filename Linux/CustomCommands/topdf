def _generate_html_output(custom_css: str, pygments_css: str, logo_html: str, html_body: str) -> str:
    return f"""
    <!DOCTYPE html>
    <html lang="en">
    <head>
        <meta charset="UTF-8">
        <style>
            {custom_css}
            {pygments_css}
        </style>
    </head>

    <body>
        {logo_html}
        {html_body}
    </body>
    </html>
    """


def _render_pdf(html: str, input_file_path: str, output_file_path: str) -> None:
    print(f"Converting '{input_file_path}' to '{output_file_path}'...")
    HTML(string=html).write_pdf(output_file_path)
    print("PDF generated successfully.")


def _apply_table_alignment(html_body: str) -> str:
    centered_pattern = r'<td>\s*\\c\s*(.*?)</td>'
    html_body = re.sub(centered_pattern, r'<td style="text-align: center;">\1</td>', html_body, flags=re.DOTALL)
    right_pattern = r'<td>\s*\\r\s*(.*?)</td>'
    return re.sub(right_pattern, r'<td style="text-align: right;">\1</td>', html_body, flags=re.DOTALL)


def convert_md_to_pdf(input_file, output_file, logo) -> None:
    """
    Converts the given markdown file to pdf.
    :param input_file: Markdown input file path.
    :param output_file: PDF output file path.
    :param logo: (Optional) Path to image file to include as logo.
    :return:
    """
    _ensure_exists(input_file=input_file)
    
    md_text = _get_md_text(input_file=input_file)
    md_text = _apply_page_breaks(md_text=md_text)
    md_text = _apply_mathjax(md_text=md_text)
    
    extensions: List[str] = ['fenced_code', 'codehilite', 'tables', 'sane_lists']
    html_body: str = _to_html(md_text=md_text, extensions=extensions)
    html_body = _apply_table_alignment(html_body)
    
    pygments_css: str = HtmlFormatter(style='default').get_style_defs('.codehilite')
    custom_css: str = _get_css()
    logo_html: str = _get_logo_html(logo)

    full_html = _generate_html_output(
        custom_css=custom_css,
        pygments_css=pygments_css,
        logo_html=logo_html,
        html_body=html_body
    )

    _render_pdf(
        html=full_html,
        input_file_path=input_file,
        output_file_path=output_file
    )
    

def main():
    parser = argparse.ArgumentParser(description="Convert Markdown to a beautifully styled PDF.")
    parser.add_argument('-i', '--input', required=True, help="Path to the input Markdown file (.md)")
    parser.add_argument('-o', '--output', required=True, help="Path to the output PDF file (.pdf)")
    parser.add_argument('-l', '--logo', required=False, help="Path to the custom logo image file.")

    args = parser.parse_args()
    convert_md_to_pdf(args.input, args.output, args.logo)

if __name__ == "__main__":
    main()
